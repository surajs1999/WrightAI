{
  "name": "wrightai",
  "displayName": "WrightAI — AI Code Documentation",
  "description": "AI-powered code documentation for VS Code. Generate docstrings, track coverage, detect drift, and chat with your codebase. Supports Python, JavaScript, TypeScript, Java, Go, and Rust.",
  "version": "0.1.24",
  "publisher": "WrightAI",
  "license": "AGPL-3.0-or-later",
  "readme": "README.md",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/surajs1999/WrightAI"
  },
  "homepage": "https://www.wrightai.live/",
  "bugs": {
    "url": "https://github.com/surajs1999/WrightAI/issues"
  },
  "keywords": [
    "ai",
    "documentation",
    "docstring",
    "python",
    "typescript",
    "javascript",
    "java",
    "go",
    "rust",
    "jsdoc",
    "autodoc",
    "code-documentation"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:java",
    "onLanguage:go",
    "onLanguage:rust"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wright.generateCurrent",
        "title": "Wright: Generate docs for this function"
      },
      {
        "command": "wright.generateFile",
        "title": "Wright: Generate docs for entire file"
      },
      {
        "command": "wright.showCoverage",
        "title": "Wright: Show coverage"
      },
      {
        "command": "wright.chat",
        "title": "Wright: Chat with codebase"
      },
      {
        "command": "wright.checkDrift",
        "title": "Wright: Check for doc drift"
      },
      {
        "command": "wright.generateCurrentFromHover",
        "title": "Wright: Generate docs (from hover)"
      }
    ],
    "keybindings": [
      {
        "command": "wright.generateCurrent",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "wright.generateCurrent",
          "when": "editorHasSelection || editorTextFocus"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "wrightCoverage",
          "name": "Wright Coverage"
        }
      ]
    },
    "configuration": {
      "title": "Wright",
      "properties": {
        "wright.apiUrl": {
          "type": "string",
          "default": "https://api.wrightai.live",
          "description": "WrightAI API server URL"
        },
        "wright.apiKey": {
          "type": "string",
          "default": "",
          "description": "Wright API key"
        },
        "wright.style": {
          "type": "string",
          "enum": [
            "google",
            "jsdoc",
            "numpy",
            "epytext",
            "rust"
          ],
          "default": "google",
          "description": "Default docstring style (used when no language-specific style is set)"
        },
        "wright.style.python": {
          "type": "string",
          "enum": [
            "google",
            "numpy",
            "epytext"
          ],
          "default": "google",
          "description": "Docstring style for Python files"
        },
        "wright.style.javascript": {
          "type": "string",
          "enum": [
            "jsdoc"
          ],
          "default": "jsdoc",
          "description": "Docstring style for JavaScript files"
        },
        "wright.style.typescript": {
          "type": "string",
          "enum": [
            "jsdoc"
          ],
          "default": "jsdoc",
          "description": "Docstring style for TypeScript files"
        },
        "wright.style.rust": {
          "type": "string",
          "enum": [
            "rust"
          ],
          "default": "rust",
          "description": "Docstring style for Rust files"
        }
      }
    }
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.24.0",
    "jimp": "^1.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
